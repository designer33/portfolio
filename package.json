{
    "name": "portfolio-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "npm run dev --workspaces --if-present",
        "dev:client": "npm run dev --workspace=client",
        "dev:server": "npm run dev --workspace=server",
        "build": "npm run build --prefix client"
    },
    "workspaces": [
        "client",
        "server"
    ],
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cloudinary": "^2.9.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.2.3",
        "multer": "^2.1.0"
    }
}