{
    "name": "portfolio-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "npm run dev --workspaces --if-present",
        "dev:client": "npm run dev --workspace=client",
        "dev:server": "npm run dev --workspace=server",
        "build": "npm run build --workspace=client"
    },
    "workspaces": [
        "client",
        "server"
    ],
    "devDependencies": {
        "vite": "^7.3.1"
    }
}